{
  "nats": {
    "url": "nats://127.0.0.1:4222",
    "username": "nats_client",
    "password": "change-me",
    "name": "tuna-entry",
    "connect_timeout": "5s",
    "reconnect_wait": "1s",
    "ping_interval": "20s",
    "max_pings_outstanding": 5,
    "max_reconnects": -1,
    "reconnect_buffer_bytes": 67108864
  },
  "tunnel": {
    "subject_prefix": "tuna",
    "data_subject_shards": 16,
    "chunk_size_bytes": 1048576,
    "write_batch_bytes": 4194304,
    "read_coalesce_min_delay": "50us",
    "read_coalesce_max_delay": "500us",
    "write_coalesce_min_delay": "50us",
    "write_coalesce_max_delay": "500us",
    "session_queue_depth": 2048,
    "queue_backpressure_timeout": "2s",
    "session_idle_timeout": "2m",
    "cleanup_interval": "15s",
    "subscription_pending_messages": 262144,
    "subscription_pending_bytes": 536870912,
    "tcp_no_delay": true,
    "tcp_keep_alive": "30s",
    "tcp_read_buffer_bytes": 4194304,
    "tcp_write_buffer_bytes": 4194304
  },
  "entry": {
    "listen_address": "127.0.0.1:1080",
    "request_timeout": "15s"
  }
}
